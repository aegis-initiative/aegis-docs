{
  "name": "aegis-docs",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "aegisGovernance": {
    "atxMinVersion": "2.3.0"
  },
  "scripts": {
    "predev": "node scripts/fetch-atx.mjs",
    "dev": "astro dev",
    "prebuild": "node scripts/fetch-atx.mjs",
    "build": "astro build && pagefind --site dist",
    "postbuild": "cp -r dist/pagefind public/",
    "preview": "astro preview",
    "astro": "astro",
    "fetch-atx": "node scripts/fetch-atx.mjs",
    "fetch-atx:check": "node scripts/fetch-atx.mjs --check",
    "fetch-atx:offline": "node scripts/fetch-atx.mjs --offline"
  },
  "dependencies": {
    "@aegis-initiative/design-system": "^0.6.0",
    "@astrojs/mdx": "^5.0.2",
    "@pagefind/default-ui": "^1.4.0",
    "astro": "^6.0.8"
  },
  "devDependencies": {
    "pagefind": "^1.4.0"
  }
}
