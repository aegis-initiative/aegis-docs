---
import Header from '../../components/Header.astro';
import Sidebar from '../../components/Sidebar.astro';
import Footer from '../../components/Footer.astro';

const tactics = [
  {
    id: "TA001", name: "Authority Boundary Violation", short: "Authority Violation",
    techniques: [
      { id: "T1001", name: "Non-Owner Instruction Compliance", severity: "high", root: "RC1", case: "CS1", owasp: "LLM06", desc: "Agent executes destructive actions based on instructions from a user without owner-level authority." },
      { id: "T1002", name: "Implicit Authority Acceptance", severity: "high", root: "RC1", case: "CS2", owasp: "LLM01", desc: "Agent accepts injected instructions as authoritative without verifying the source." },
      { id: "T1003", name: "Mass Distribution Under Spoofed Authority", severity: "critical", root: "RC1", case: "CS3", owasp: "LLM06", desc: "Agent sends mass communications impersonating an authority figure." },
    ]
  },
  {
    id: "TA002", name: "Destructive Action", short: "Destructive Action",
    techniques: [
      { id: "T2001", name: "Irreversible Collateral Action", severity: "critical", root: "RC2", case: "CS4", owasp: "LLM07", desc: "Agent performs destructive operations (deletion, overwrite) without safeguards or rollback capability." },
      { id: "T2002", name: "Cascading Multi-System Damage", severity: "critical", root: "RC2+RC3", case: "CS5", owasp: "LLM07", desc: "Agent failure propagates across multiple systems causing widespread damage." },
      { id: "T2003", name: "Unvalidated Bulk Operation", severity: "high", root: "RC2", case: "CS6", owasp: "LLM07", desc: "Agent executes operations at scale without validating scope or confirming intent." },
    ]
  },
  {
    id: "TA003", name: "Scope Violation", short: "Scope Violation",
    techniques: [
      { id: "T3001", name: "Autonomous Scope Expansion", severity: "high", root: "RC2+RC3", case: "CS7", owasp: "LLM01", desc: "Agent expands its own task boundaries beyond original instructions." },
    ]
  },
  {
    id: "TA004", name: "Information Breach", short: "Info Breach",
    techniques: [
      { id: "T4001", name: "Context Window Data Exfiltration", severity: "critical", root: "RC1+RC4", case: "CS8", owasp: "LLM02", desc: "Agent leaks sensitive data from its context window to unauthorized recipients." },
      { id: "T4002", name: "Cross-Session Information Leakage", severity: "high", root: "RC3", case: "CS9", owasp: "LLM02", desc: "Agent carries information between sessions that should be isolated." },
    ]
  },
  {
    id: "TA005", name: "Deceptive Output", short: "Deceptive Output",
    techniques: [
      { id: "T5001", name: "False Task Completion Report", severity: "high", root: "RC2", case: "CS10", owasp: "LLM06", desc: "Agent reports successful completion of tasks it did not perform or performed incorrectly." },
      { id: "T5002", name: "Hallucinated Action Attribution", severity: "medium", root: "RC2", case: "CS10", owasp: "LLM06", desc: "Agent fabricates evidence of actions it claims to have taken." },
    ]
  },
  {
    id: "TA006", name: "Resource Abuse", short: "Resource Abuse",
    techniques: [
      { id: "T6001", name: "Recursive Self-Invocation Loop", severity: "high", root: "RC2+RC3", case: "CS11", owasp: "LLM10", desc: "Agent enters an unbounded loop of self-invocation consuming resources indefinitely." },
      { id: "T6002", name: "Unbounded External API Consumption", severity: "medium", root: "RC2", case: "CS11", owasp: "LLM10", desc: "Agent makes excessive external API calls without rate limiting." },
    ]
  },
  {
    id: "TA007", name: "Multi-Agent Exploitation", short: "Multi-Agent",
    techniques: [
      { id: "T7001", name: "Agent Identity Spoofing", severity: "critical", root: "RC1", case: "CS3", owasp: "LLM06", desc: "Agent impersonates another agent or authority in multi-agent pipelines." },
      { id: "T7002", name: "Delegation Chain Injection", severity: "high", root: "RC1+RC4", case: "CS8", owasp: "LLM01", desc: "Attacker injects instructions into agent delegation chains." },
    ]
  },
  {
    id: "TA008", name: "Persistence Violation", short: "Persistence",
    techniques: [
      { id: "T8001", name: "Memory Poisoning via Injected Context", severity: "high", root: "RC4", case: "CS2", owasp: "LLM01", desc: "Agent's persistent memory is corrupted through injected context." },
      { id: "T8002", name: "Governance State Corruption", severity: "critical", root: "RC4", case: "CS8", owasp: "LLM01", desc: "Agent manipulates its own governance state to bypass constraints." },
    ]
  },
  {
    id: "TA009", name: "Monitoring Evasion", short: "Evasion",
    techniques: [
      { id: "T9001", name: "Silent Provider-Level Task Failure", severity: "medium", root: "RC2", case: "CS10", owasp: "LLM06", desc: "Agent task fails silently at the provider level without generating alerts or logs." },
    ]
  },
];
---

<!doctype html>
<html lang="en" dir="ltr" data-theme="auto">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>ATX-1 Matrix — AEGIS Threat Matrix</title>
  <meta name="description" content="Interactive matrix view of the ATX-1 threat taxonomy — 9 tactics, 20 techniques for autonomous AI agent governance." />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <script src="https://aegis-initiative.com/shared/aegis-nav.js" defer></script>

  <link rel="preload" href="/fonts/ibmplexsans-variablefont_wdthwght-webfont.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/poppins-light-webfont.woff2" as="font" type="font/woff2" crossorigin />

  <script is:inline>
    (function () {
      const stored = localStorage.getItem("aegis-theme");
      const preferred = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      document.documentElement.dataset.theme = stored || preferred;
      document.documentElement.style.setProperty('--aegis-nav-height', '32px');
    })();
  </script>

  <style>
    @font-face {
      font-family: "IBM Plex Sans";
      src: url("/fonts/ibmplexsans-variablefont_wdthwght-webfont.woff2") format("woff2");
      font-weight: 100 700;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: "Poppins";
      src: url("/fonts/poppins-light-webfont.woff2") format("woff2");
      font-weight: 300;
      font-style: normal;
      font-display: swap;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --color-bg: #ffffff;
      --color-text: #1b1b1b;
      --color-text-secondary: #454545;
      --color-text-muted: #757575;
      --color-accent: #005ea2;
      --color-border: #d4d4d4;
      --color-border-subtle: #e8e8e8;
      --header-bg: #ffffff;
      --header-border: #d4d4d4;
      --sidebar-bg: #f8f8f8;
      --matrix-card-bg: #f4f4f4;
      --matrix-card-hover: #eaeaea;
      --matrix-header-bg: #e8e8e8;
      --overlay-bg: rgba(0,0,0,0.4);
      --detail-bg: #ffffff;
      --detail-meta-bg: #f4f4f4;
    }

    [data-theme="dark"] {
      --color-bg: #161616;
      --color-text: #f4f4f4;
      --color-text-secondary: #c6c6c6;
      --color-text-muted: #8d8d8d;
      --color-accent: #73b3e7;
      --color-border: #393939;
      --color-border-subtle: #262626;
      --header-bg: #1b1b1b;
      --header-border: #393939;
      --sidebar-bg: #1b1b1b;
      --matrix-card-bg: #1b1b1b;
      --matrix-card-hover: #262626;
      --matrix-header-bg: #262626;
      --overlay-bg: rgba(0,0,0,0.6);
      --detail-bg: #1b1b1b;
      --detail-meta-bg: #262626;
    }

    html {
      font-family: "Poppins", system-ui, sans-serif;
      font-size: 14px;
      font-weight: 300;
      line-height: 1.7;
      color: var(--color-text);
      background-color: var(--color-bg);
    }

    @media (min-width: 560px) { html { font-size: 16px; } }

    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    h1, h2, h3 {
      font-family: "IBM Plex Sans", system-ui, sans-serif;
      font-weight: 400;
      line-height: 1.3;
    }

    .page-wrapper {
      display: flex;
      flex: 1;
      width: 100%;
    }

    .main-content {
      flex: 1;
      min-width: 0;
      padding: 1.5rem;
    }

    @media (min-width: 1024px) {
      .main-content {
        margin-left: 320px;
      }
    }

    /* Matrix-specific styles */
    .matrix-hero {
      text-align: center;
      padding: 1.5rem 0 0.5rem;
    }

    .matrix-hero h1 {
      font-size: 1.6rem;
      margin-bottom: 0.4rem;
    }

    .matrix-hero p {
      color: var(--color-text-muted);
      font-size: 0.9rem;
      max-width: 700px;
      margin: 0 auto;
    }

    .legend {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      padding: 0.75rem 0 1rem;
      flex-wrap: wrap;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.8rem;
      color: var(--color-text-muted);
    }

    .legend-dot {
      width: 12px;
      height: 12px;
      border-radius: 3px;
    }

    .matrix-container {
      overflow-x: auto;
      padding-bottom: 2rem;
    }

    .matrix {
      display: grid;
      grid-template-columns: repeat(9, minmax(130px, 1fr));
      gap: 3px;
      min-width: 1200px;
    }

    .tactic-header {
      background: var(--matrix-header-bg);
      border: 1px solid var(--color-border);
      border-radius: 6px 6px 0 0;
      padding: 0.6rem 0.4rem;
      text-align: center;
    }

    .tactic-id {
      font-family: 'Cascadia Code', 'Fira Code', monospace;
      font-size: 0.65rem;
      color: var(--color-text-muted);
      margin-bottom: 0.2rem;
    }

    .tactic-name {
      font-family: "IBM Plex Sans", system-ui, sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      line-height: 1.3;
    }

    .tactic-column {
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .technique-cell {
      border-radius: 4px;
      padding: 0.5rem 0.4rem;
      cursor: pointer;
      transition: all 0.15s;
      border: 1px solid var(--color-border);
      background: var(--matrix-card-bg);
    }

    .technique-cell:hover {
      background: var(--matrix-card-hover);
      transform: translateY(-1px);
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    [data-theme="dark"] .technique-cell:hover {
      box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }

    .technique-id {
      font-family: 'Cascadia Code', 'Fira Code', monospace;
      font-size: 0.6rem;
      color: var(--color-text-muted);
      margin-bottom: 0.15rem;
    }

    .technique-name {
      font-size: 0.7rem;
      font-weight: 500;
      line-height: 1.3;
    }

    .severity-badge {
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 600;
      margin-top: 0.25rem;
      display: inline-block;
      padding: 0.1rem 0.35rem;
      border-radius: 3px;
    }

    .severity-critical { background: #f8514922; color: #d1242f; }
    .severity-high { background: #d2992222; color: #b35900; }
    .severity-medium { background: #58a6ff22; color: #0969da; }
    .severity-low { background: #3fb95022; color: #1a7f37; }

    [data-theme="dark"] .severity-critical { background: #3b1219; color: #ff7b72; }
    [data-theme="dark"] .severity-high { background: #2a1f00; color: #f0b840; }
    [data-theme="dark"] .severity-medium { background: #1c2333; color: #79c0ff; }
    [data-theme="dark"] .severity-low { background: #0d2818; color: #56d364; }

    /* Detail overlay */
    .detail-overlay {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: var(--overlay-bg);
      z-index: 200;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .detail-overlay.active { display: flex; }

    .detail-panel {
      background: var(--detail-bg);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      max-width: 560px;
      width: 100%;
      padding: 1.75rem;
      position: relative;
      max-height: 80vh;
      overflow-y: auto;
    }

    .detail-close {
      position: absolute;
      top: 0.75rem;
      right: 1rem;
      background: none;
      border: none;
      color: var(--color-text-muted);
      font-size: 1.5rem;
      cursor: pointer;
    }

    .detail-close:hover { color: var(--color-text); }

    .detail-panel h2 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 0.2rem;
      padding-right: 2rem;
    }

    .detail-panel .detail-id {
      font-family: 'Cascadia Code', 'Fira Code', monospace;
      font-size: 0.8rem;
      color: var(--color-text-muted);
      margin-bottom: 0.75rem;
    }

    .detail-panel .detail-desc {
      font-size: 0.9rem;
      color: var(--color-text-secondary);
      line-height: 1.6;
      margin-bottom: 1.25rem;
    }

    .detail-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.6rem;
    }

    .detail-meta-item {
      background: var(--detail-meta-bg);
      border: 1px solid var(--color-border);
      border-radius: 6px;
      padding: 0.5rem 0.65rem;
    }

    .detail-meta-label {
      font-size: 0.65rem;
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.15rem;
    }

    .detail-meta-value {
      font-size: 0.8rem;
      font-weight: 500;
    }

    .detail-link {
      display: inline-block;
      margin-top: 1.25rem;
      color: var(--color-accent);
      text-decoration: none;
      font-size: 0.85rem;
    }

    .detail-link:hover { text-decoration: underline; }

    .matrix-links {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      padding: 0 0 1.5rem;
      font-size: 0.85rem;
    }

    .matrix-links a {
      color: var(--color-accent);
      text-decoration: none;
    }

    .matrix-links a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <Header />
  <div class="page-wrapper">
    <Sidebar />
    <main class="main-content">

      <section class="matrix-hero">
        <h1>ATX-1: AEGIS Threat Matrix</h1>
        <p>Adversarial knowledge base for autonomous AI agent behavior. 9 tactics, 20 techniques — empirically grounded in observed agentic failures.</p>
      </section>

      <div class="legend">
        <div class="legend-item">
          <div class="legend-dot severity-critical" style="width:12px;height:12px;border-radius:3px;"></div>
          Critical
        </div>
        <div class="legend-item">
          <div class="legend-dot severity-high" style="width:12px;height:12px;border-radius:3px;"></div>
          High
        </div>
        <div class="legend-item">
          <div class="legend-dot severity-medium" style="width:12px;height:12px;border-radius:3px;"></div>
          Medium
        </div>
        <div class="legend-item">
          <div class="legend-dot severity-low" style="width:12px;height:12px;border-radius:3px;"></div>
          Low
        </div>
      </div>

      <div class="matrix-links">
        <a href="/threat-matrix">Documentation</a>
        <a href="/threat-matrix/techniques">Technique Details</a>
        <a href="/threat-matrix/regulatory-crossref">Regulatory Mapping</a>
        <a href="https://aegis-governance.com/atx-1/index.json">Data (JSON)</a>
      </div>

      <div class="matrix-container">
        <div class="matrix">
          {tactics.map((tactic) => (
            <div class="tactic-column">
              <div class="tactic-header">
                <div class="tactic-id">{tactic.id}</div>
                <div class="tactic-name">{tactic.short}</div>
              </div>
              {tactic.techniques.map((tech) => (
                <div
                  class="technique-cell"
                  data-id={tech.id}
                  data-name={tech.name}
                  data-severity={tech.severity}
                  data-root={tech.root}
                  data-case={tech.case}
                  data-owasp={tech.owasp}
                  data-desc={tech.desc}
                  data-tactic={`${tactic.id}: ${tactic.name}`}
                >
                  <div class="technique-id">{tech.id}</div>
                  <div class="technique-name">{tech.name}</div>
                  <div class={`severity-badge severity-${tech.severity}`}>{tech.severity}</div>
                </div>
              ))}
            </div>
          ))}
        </div>
      </div>

      <Footer />
    </main>
  </div>

  <div class="detail-overlay" id="detail-overlay">
    <div class="detail-panel">
      <button class="detail-close" id="detail-close">&times;</button>
      <h2 id="detail-name"></h2>
      <div class="detail-id" id="detail-id"></div>
      <div class="detail-desc" id="detail-desc"></div>
      <div class="detail-meta">
        <div class="detail-meta-item">
          <div class="detail-meta-label">Severity</div>
          <div class="detail-meta-value" id="detail-severity"></div>
        </div>
        <div class="detail-meta-item">
          <div class="detail-meta-label">Tactic</div>
          <div class="detail-meta-value" id="detail-tactic"></div>
        </div>
        <div class="detail-meta-item">
          <div class="detail-meta-label">Root Cause</div>
          <div class="detail-meta-value" id="detail-root"></div>
        </div>
        <div class="detail-meta-item">
          <div class="detail-meta-label">OWASP LLM</div>
          <div class="detail-meta-value" id="detail-owasp"></div>
        </div>
        <div class="detail-meta-item">
          <div class="detail-meta-label">Case Study</div>
          <div class="detail-meta-value" id="detail-case"></div>
        </div>
      </div>
      <a class="detail-link" id="detail-link" href="#">View full technique details &rarr;</a>
    </div>
  </div>

  <script is:inline>
    document.querySelectorAll('.technique-cell').forEach(function(cell) {
      cell.addEventListener('click', function() {
        var overlay = document.getElementById('detail-overlay');
        document.getElementById('detail-name').textContent = cell.dataset.name;
        document.getElementById('detail-id').textContent = cell.dataset.id + ' \u2014 ' + cell.dataset.tactic;
        document.getElementById('detail-desc').textContent = cell.dataset.desc;
        document.getElementById('detail-severity').textContent = cell.dataset.severity.charAt(0).toUpperCase() + cell.dataset.severity.slice(1);
        document.getElementById('detail-tactic').textContent = cell.dataset.tactic;
        document.getElementById('detail-root').textContent = cell.dataset.root;
        document.getElementById('detail-owasp').textContent = cell.dataset.owasp;
        document.getElementById('detail-case').textContent = cell.dataset.case;
        document.getElementById('detail-link').href = '/threat-matrix/techniques#' + cell.dataset.id.toLowerCase();
        overlay.classList.add('active');
      });
    });

    document.getElementById('detail-close').addEventListener('click', function() {
      document.getElementById('detail-overlay').classList.remove('active');
    });

    document.getElementById('detail-overlay').addEventListener('click', function(e) {
      if (e.target === e.currentTarget) {
        e.currentTarget.classList.remove('active');
      }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        document.getElementById('detail-overlay').classList.remove('active');
      }
    });
  </script>
</body>
</html>
